# Bot Configuration
TOKEN=your_bot_token_here
API_ID=your_api_id
API_HASH=your_api_hash

# Admin Configuration
ADMIN_IDS=your_telegram_id

# Performance Configuration
MAX_CONCURRENT_CHECKS=100
CHECK_TIMEOUT=15
SPAMBOT_WAIT_TIME=2.0

# TData Pipeline
TDATA_PIPELINE_CONVERT_CONCURRENT=100
TDATA_PIPELINE_CHECK_CONCURRENT=50
TDATA_PIPELINE_CONVERT_TIMEOUT=5

# Proxy Configuration
USE_PROXY=false
PROXY_TIMEOUT=60
PROXY_FILE=proxy.txt

# TRON Wallet (optional)
TRON_WALLET_ADDRESS=
TRONGRID_API_KEY=

# Database
DATABASE_PATH=bot_data.db

# Logging
LOG_LEVEL=INFO

# Test Contact Phones
TEST_CONTACT_PHONES=+213540775893,+254771625090

# Cleanup Config
CLEANUP_UPDATE_INTERVAL=10
TDATA_CONVERT_TIMEOUT=30
CLEANUP_SINGLE_ACCOUNT_TIMEOUT=300
CLEANUP_OPERATION_TIMEOUT=60

# Contact Check
CONTACT_CHECK_MAX_CONCURRENT=30
CONTACT_CHECK_DELAY_BETWEEN=0.3
SINGLE_ACCOUNT_TIMEOUT=30
BATCH_TIMEOUT=1800
UPDATE_INTERVAL=5

# Proxy Settings
PROXY_FAST_MODE=false
PROXY_CHECK_CONCURRENT=100
PROXY_CHECK_TIMEOUT=10
PROXY_USAGE_LOG_LIMIT=10000

# VIP Settings
VIP_CHECK_LIMIT=999999
FREE_CHECK_LIMIT=5

# Language
DEFAULT_LANGUAGE=zh

# Bot Settings
BOT_USERNAME=
SUPPORT_CHAT=
CHANNEL_USERNAME=

# Payment Settings
USDT_PRICE_PER_MONTH=5
PAYMENT_TIMEOUT=1800

# Batch Creation
BATCH_MAX_ACCOUNTS=100
